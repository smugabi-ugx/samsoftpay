# Copy this file to .env and fill in your values.
# .env is git-ignored. NEVER commit real keys.

# ── Flask ────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
BASE_URL=https://yourdomain.com

# ── MTN MoMo ─────────────────────────────────────────────────────
# Set MOMO_USE_REAL=1 to hit the real MTN sandbox; 0 = local mock.
MOMO_USE_REAL=0

MOMO_SUBSCRIPTION_KEY=replace_with_your_collections_primary_key
MOMO_API_USER=replace_with_the_uuid_you_generated
MOMO_API_KEY=replace_with_the_apikey_response

MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=replace_with_your_disbursement_primary_key
MOMO_DISBURSEMENT_API_USER=replace_with_disbursement_uuid
MOMO_DISBURSEMENT_API_KEY=replace_with_disbursement_apikey

MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_TARGET_ENV=sandbox
MOMO_CURRENCY=EUR

# ── Visa / Mastercard via Flutterwave ────────────────────────────
# Get your secret key from dashboard.flutterwave.com
# Leave blank to use the mock (for local development).
FLUTTERWAVE_SECRET_KEY=

# ── Crypto via ChangeNow ──────────────────────────────────────────
# 1. Get your API key from changenow.io/developers
# 2. Create a USDT wallet (e.g. Trust Wallet on BSC)
# 3. Set CHANGENOW_RECEIVING_ADDRESS to that wallet address
# Leave blank to use the mock.
CHANGENOW_API_KEY=
CHANGENOW_RECEIVING_ADDRESS=
CHANGENOW_RECEIVING_NETWORK=bsc

# ── Email / 2FA ───────────────────────────────────────────────────
# Leave MAIL_HOST blank — OTPs print to the console in dev mode.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@samsoftpay.com

# ── Misc ──────────────────────────────────────────────────────────
RAIL_CALLBACK_DELAY_SECONDS=5
RAIL_SUCCESS_PROBABILITY=0.85
WEBHOOK_SIGNING_SECRET=whsec_change_me_in_production
