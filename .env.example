# Copy this file to .env and fill in your real values.
# .env is git-ignored. NEVER commit real keys.

# Set to 1 to use the real MTN MoMo sandbox. 0 (or unset) uses the local mock.
MOMO_USE_REAL=1

# These come from momodeveloper.mtn.com. See README for how to generate.
MOMO_SUBSCRIPTION_KEY=replace_with_your_collections_primary_key
MOMO_API_USER=replace_with_the_uuid_you_generated
MOMO_API_KEY=replace_with_the_apikey_response

# Disbursement product (separate subscription on momodeveloper.mtn.com).
# Used for payouts to merchants and refunds to customers.
MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=replace_with_your_disbursement_primary_key
MOMO_DISBURSEMENT_API_USER=replace_with_disbursement_uuid
MOMO_DISBURSEMENT_API_KEY=replace_with_disbursement_apikey

# Sandbox defaults — don't change unless you know why.
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_TARGET_ENV=sandbox
MOMO_CURRENCY=EUR

# Optional: keep the demo's mock fast settings for the airtel/card channels.
RAIL_CALLBACK_DELAY_SECONDS=5
RAIL_SUCCESS_PROBABILITY=0.85
